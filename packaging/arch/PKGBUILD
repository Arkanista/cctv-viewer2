# Maintainer: arkanista <arkanista@cctv-viewer2.org>

pkgname=kvision
pkgver=2.4.4
pkgrel=1
pkgdesc="KVision - viewer and mounter video streams with Hikvision SDK integration"
arch=('x86_64')
url="https://github.com/arkanista/kvision"
license=('GPL3')
changelog=changelog
conflicts=('cctv-viewer' 'cctv-viewer-git' 'cctv-viewer2')
provides=('kvision' 'cctv-viewer' 'cctv-viewer2')
replaces=('cctv-viewer2')
depends=('qt5-declarative' 'qt5-multimedia' 'qt5-quickcontrols' 'qt5-quickcontrols2' 'qt5-svg' 'ffmpeg' 'qt5-graphicaleffects' 'qt5-wayland')
makedepends=('cmake' 'qt5-tools' 'git')
source=("kvision::git+file://${startdir}/../..")
sha256sums=('SKIP')

prepare() {
  cd "$srcdir/kvision"
  git submodule init
  git config submodule.src/qmlav.url "${startdir}/../../src/qmlav"
  git -c protocol.file.allow=always submodule update --recursive
}

build() {
  # Run cmake configuration and build
  cmake -B build -S "$srcdir/kvision" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DVER_REL=${pkgrel}
  cmake --build build
}

package() {
  # Install target files to $pkgdir
  DESTDIR="$pkgdir" cmake --install build
}
